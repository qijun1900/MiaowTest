# 环境配置示例
# 复制此文件为 .env.development 或 .env.production 进行配置

# 应用标题
VITE_APP_TITLE=题喵喵管理后台

# 环境标识 (development / production)
VITE_APP_ENV=development

# 后端服务器配置
VITE_SERVER_HOST=localhost
VITE_SERVER_PORT=3000

# OSS 配置
VITE_OSS_ENABLED=false
VITE_OSS_DOMAIN=https://your-bucket.oss-cn-hangzhou.aliyuncs.com
VITE_OSS_BUCKET=your-bucket
VITE_OSS_REGION=oss-cn-hangzhou
