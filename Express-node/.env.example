# ===========================================
# 答题系统环境变量配置模板
# 复制此文件为 .env 并修改相应的值
# ===========================================

# ============= 基础服务配置 =============
# #环境 development:开发环境，production:生产环境
NODE_ENV=development

# 服务监听端口（默认3000）
PORT=3000

# 服务名称（用于区分不同的服务实例）
#K_SERVICE = 本地 #服务名称 '云托管' : '本地'

# 服务监听地址（默认0.0.0.0，支持localhost和127.0.0.1访问）
# 本地开发可设置为：localhost 或 127.0.0.1 或 0.0.0.0
# 云部署必须使用：0.0.0.0
HOST=0.0.0.0

# ============= 数据库配置 =============
# 数据库提供商类型：local（本地）/ 1panel（面板部署）/ cloud（云数据库）
MONGO_PROVIDER=local

#===========1panel配置mongodb数据库===========
MONGO_USERNAME= YOUR #数据库用户名
MONGO_PASSWORD=YOUR #数据库密码
MONGO_HOST=YOUR #数据库地址
MONGO_PORT= YOUR #数据库端口
MONGO_DATABASE=YOUR #数据库名称

#===========cloud配置mongodb数据库===========
MONGO_CLOUD_USERNAME= YOUR #数据库用户名
MONGO_CLOUD_PASSWORD= YOUR #数据库密码
MONGO_CLOUD_HOST= YOUR #数据库地址 云地址
MONGO_CLOUD_PORT= YOUR #数据库端口
MONGO_CLOUD_DATABASE=YOUR #数据库名称

# ============= 微信小程序配置 =============
# 从微信公众平台获取
WECHAT_APPID=your-WECHAT_APPID
WECHAT_SECRET=your-WECHAT_SECRET
# 微信云托管云环境ID（用于服务端删除云存储文件，如 prod-xxx）
CLOUD_ENV= prod-xxx

# =============API Key AI模型配置 =============
# *阿里云大模型API密钥（用于智能问答等功能）
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============= 阿里云oss存储 =============
OSS_REGION=# 阿里云 OSS 区域
OSS_ACCESS_KEY_ID=# *阿里云 OSS 访问密钥 ID
OSS_ACCESS_KEY_SECRET=# *阿里云 OSS 访问密钥 Secret
OSS_BUCKET= # 阿里云 OSS 存储桶名称
OSS_INTERNAL= # 是否使用阿里云内部网络
OSS_SECURE= # 是否使用 HTTPS
OSS_PREFIX=# 阿里云 OSS 存储路径前缀(可以为空)
OSS_CDN_DOMAIN=# 阿里云 OSS CDN 域名

# ============= 邮件 SMTP 配置 =============
# 用于发送邮箱验证码
#
# 【使用说明】
#   1. 从下方选择一个服务商，将其配置块取消注释并填入真实值
#   2. 将其余服务商配置块保持注释状态
#   3. EMAIL_PROVIDER 会让代码自动匹配该服务商的 host/port/secure，无需手动填写
#
# ---------------------------------------------------------------
# 方案一：阿里云邮件推送 DirectMail【推荐生产环境】
#   免费额度: 每天 200 封 | 需绑定自己的域名
#   控制台: https://dm.console.aliyun.com
#   开通步骤:
#     ① 控制台 → 发信域名 → 新建域名 → 按提示在 DNS 添加 3 条解析记录并验证
#     ② 发信地址 → 新建发信地址（如 noreply@yourdomain.com）→ 状态变为"正常"
#     ③ SMTP 密码 → 设置密码（此密码即 EMAIL_PASS，与阿里云账号密码无关）
#
# EMAIL_PROVIDER=aliyun
# EMAIL_USER=noreply@yourdomain.com       # 控制台创建的发信地址
# EMAIL_PASS=your-aliyun-smtp-password    # 控制台单独设置的 SMTP 密码
#
# ---------------------------------------------------------------
# 方案二：腾讯云邮件推送 SES 【推荐生产环境】
#   免费额度: 每天 200 封 | 可使用腾讯云默认域名
#   控制台: https://console.cloud.tencent.com/ses
#   开通步骤:
#     ① 控制台 → 发信域名 → 新建（可选腾讯云提供的默认子域名）→ 完成验证
#     ② 发信地址 → 新建（如 noreply@your-ses-domain.com）
#     ③ SMTP 密码 → 新建密码（此密码即 EMAIL_PASS）
#
# EMAIL_PROVIDER=tencent
# EMAIL_USER=noreply@your-ses-domain.com  # 控制台创建的发信地址
# EMAIL_PASS=your-tencent-smtp-password   # 控制台新建的 SMTP 密码
#
# ---------------------------------------------------------------
# 方案三：QQ 邮箱【仅限开发测试，生产环境不推荐】
#   ⚠️  每日约 200 封上限，易触发风控封号，邮件易进垃圾箱
#   开通步骤:
#     ① 登录 QQ 邮箱网页版 → 设置 → 账户
#     ② 找到「POP3/IMAP/SMTP 服务」→ 开启「IMAP/SMTP 服务」
#     ③ 按短信验证步骤完成验证，页面弹出 16 位授权码 → 立即复制保存
#     ⚠️  EMAIL_PASS 填授权码（16位字母），不是 QQ 登录密码！
#
# EMAIL_PROVIDER=qq
# EMAIL_USER=your-qq-number@qq.com        # 完整 QQ 邮箱地址
# EMAIL_PASS=abcdefghijklmnop             # 16 位授权码，非 QQ 登录密码
#
# ---------------------------------------------------------------
# 方案四：163 邮箱【仅限开发测试，生产环境不推荐】
#   ⚠️  每日约 200 封上限，163 对 SMTP 校验较严格
#   开通步骤:
#     ① 登录 163 邮箱网页版 → 设置 → POP3/SMTP/IMAP
#     ② 开启「SMTP 服务」→ 按页面提示绑定手机并生成授权码
#     ⚠️  EMAIL_PASS 填授权码，不是 163 登录密码！
#
# EMAIL_PROVIDER=163
# EMAIL_USER=your-account@163.com         # 163 邮箱地址
# EMAIL_PASS=your-163-auth-code           # 授权码，非 163 登录密码
#
# ---------------------------------------------------------------
# ★ 将你选择的方案取消注释、填入真实值，其余保持注释 ★

EMAIL_PROVIDER=aliyun  # aliyun | tencent | qq | 163
EMAIL_USER=noreply@yourdomain.com
EMAIL_PASS=your-smtp-password
# 邮件中显示的应用名称（出现在主题和正文中）
APP_NAME=题喵喵
# 发件人显示名称（可选，默认与 APP_NAME 相同）
# EMAIL_SENDER_NAME=题喵喵官方
