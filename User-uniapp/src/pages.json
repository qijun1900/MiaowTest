{
	"easycom": {
		"autoscan": true,
		"custom": {
			// uni-ui 规则如下配置
			"^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue",
			// TDesign Chat 组件(需放在通用 TDesign 规则之前优先匹配)
			"^t-(chat-.*|attachments)$": "@tdesign/uniapp-chat/$1/$1.vue",
			// TDesign 规则如下配置
			"^t-(.*)": "@tdesign/uniapp/$1/$1.vue"
		}
	},
	"pages": [ //pages数组中第一项表示应用启动页，参考：https://uniapp.dcloud.io/collocation/pages
		{
			"path": "pages/index/index",
			"style": {
				"navigationBarTitleText": "题喵喵",
				"navigationStyle": "custom",
				"navigationBarTextStyle": "black",
				"navigationBarBackgroundColor": "#f5f7fa",
				"enablePullDownRefresh": true,
				"app-plus": {
					"scrollIndicator": "none",
					"pullToRefresh": {
						"support": true, // 是否支持下拉刷新
						"style": "circle",
						"color": "#888888" // 下拉刷新圆圈颜色，使用中性灰适配所有主题
					}
				}
			}
		},
		{
			"path": "pages/tab/my",
			"style": {
				"navigationBarTitleText": "我的",
				"navigationStyle": "custom",
				"disableScroll": false, // 允许页面滚动
				"app-plus": {
					"scrollIndicator": "none",
					"pullToRefresh": {
						"support": true, // 是否支持下拉刷新
						"style": "circle",
						"color": "#888888"
					}
				},
				"enablePullDownRefresh": true,
				"backgroundColor": "#F8FDFF"
			}
		},
		{
			"path": "pages/tab/exam",
			"style": {
				"navigationBarTitleText": "所有考试",
				"navigationStyle": "custom",
				"disableScroll": false, // 允许页面滚动
				"enablePullDownRefresh": true, // 启用下拉刷新
				"backgroundColor": "#F8FDFF", // 页面背景色
				"navigationBarTextStyle": "black", // 导航栏文字颜色
				"app-plus": {
					"bounce": "none",
					"scrollIndicator": "none",
					"pullToRefresh": {
						"support": true, // 是否支持下拉刷新
						"style": "circle",
						"color": "#888888"
					}
				}
			}
		},
		{
			"path": "pages/tab/tools",
			"style": {
				"navigationBarTitleText": "所有工具",
				"navigationStyle": "custom",
				"disableScroll": false,
				"navigationBarTextStyle": "black"
			}
		},
		{
			"path": "pages/tab/agent",
			"style": {
				"navigationBarTitleText": "Agent",
				"navigationStyle": "custom",
				"disableScroll": false,
				"navigationBarTextStyle": "black",
				"backgroundColor": "#F8FDFF",
				"app-plus": {
					"scrollIndicator": "none",
					"softinputMode": "adjustResize"
				}
			}
		}
	],
